# ===========================
# Customizable Embed Text - Welcome / Leaving
# ===========================

# Welcome message title
WELCOME_TITLE=Welcome!

# Welcome message description ({user} = mention, {server} = server name, {count} = member count)
WELCOME_DESCRIPTION=Welcome to **{server}**, {user}!\n\n**Member Count:** {count}

# Leaving message title
LEAVING_TITLE=Goodbye!

# Leaving message description ({user} = user tag, {server} = server name, {count} = member count)
LEAVING_DESCRIPTION=**{user}** has left **{server}**.\n\n**Member Count:** {count}

# ===========================
# Customizable Embed Text - Sessions
# ===========================

# SSU title
SSU_TITLE=Server Startup

# SSU description ({server} = server name, {players} = player count, {max} = max players, {owner} = owner mention)
SSU_DESCRIPTION=The server is now starting up!\n\n**Server:** {server}\n**Players:** {players}/{max}\n**Owner:** {owner}\n**Status:** Starting

# SSD title
SSD_TITLE=Server Shutdown

# SSD description ({host} = host user mention)
SSD_DESCRIPTION=The server is now shutting down.\n\n**Host:** {host}\n**Status:** Offline

# SSU Vote title
SSU_VOTE_TITLE=SSU Vote

# SSU Vote description ({votes} = current, {threshold} = required)
SSU_VOTE_DESCRIPTION=Vote to start up the server!\n\n**Votes:** {votes}/{threshold}\n\nClick the button below to vote!

# SSU Vote passed title
SSU_VOTE_PASSED_TITLE=SSU Vote -- Passed!

# SSU Vote passed description ({votes} = count, {threshold} = required)
SSU_VOTE_PASSED_DESCRIPTION=The vote has passed! The server is starting up!\n\n**Votes:** {votes}/{threshold}

# SSU Vote button label
SSU_VOTE_BUTTON_LABEL=Vote

# ===========================
# Customizable Embed Text - Infractions
# ===========================

# Infraction added title
INFRACTION_ADDED_TITLE=Infraction Added

# Infraction removed message ({id} = infraction ID)
INFRACTION_REMOVED_MSG=Infraction {id} has been removed.

# Infraction list title ({user} = user tag)
INFRACTION_LIST_TITLE=Infractions for {user}

# ===========================
# Customizable Embed Text - Promotions
# ===========================

# Promotion title
PROMOTION_TITLE=Promotion

# Promotion description ({user} = promoted user mention)
PROMOTION_DESCRIPTION={user} has been promoted!

# Promotion history title ({user} = user tag)
PROMOTION_HISTORY_TITLE=Promotion History for {user}

# ===========================
# Customizable Embed Text - Tickets
# ===========================

# Ticket panel title
TICKET_PANEL_TITLE=Support Tickets

# Ticket panel description
TICKET_PANEL_DESCRIPTION=Select a ticket type below to create a ticket.\nOur staff team will assist you shortly.

# Ticket type button labels
TICKET_BTN_GENERAL=General
TICKET_BTN_MANAGEMENT=Management
TICKET_BTN_OWNERSHIP=Ownership

# Ticket type button labels (configured above in Ticket section)
# TICKET_BTN_GENERAL, TICKET_BTN_MANAGEMENT, TICKET_BTN_OWNERSHIP

# Ticket opened title
TICKET_OPENED_TITLE=Ticket Opened

# Ticket opened description ({user} = ticket creator mention)
TICKET_OPENED_DESCRIPTION=Welcome {user}! A staff member will be with you shortly.\nClick the button below to close this ticket.

# Ticket close button label
TICKET_CLOSE_BUTTON_LABEL=Close Ticket

# Ticket closed log title
TICKET_CLOSED_TITLE=Ticket Closed

# ===========================
# Customizable Embed Text - Giveaways
# ===========================

# Giveaway title
GIVEAWAY_TITLE=Giveaway

# Giveaway description ({prize} = prize, {winners} = winner count, {ends} = end time, {host} = host mention)
GIVEAWAY_DESCRIPTION=**{prize}**\n\nClick the button to enter!\n**Winners:** {winners}\n**Ends:** {ends}\n**Hosted by:** {host}

# Giveaway ended title
GIVEAWAY_ENDED_TITLE=Giveaway Ended

# Giveaway ended description ({prize} = prize, {winners} = winner mentions, {host} = host mention)
GIVEAWAY_ENDED_DESCRIPTION=**{prize}**\n\n**Winners:** {winners}\n**Hosted by:** {host}

# Giveaway enter button label ({count} = entry count)
GIVEAWAY_ENTER_BUTTON_LABEL=Enter ({count})

# Giveaway winner announcement ({winners} = winner mentions, {prize} = prize)
GIVEAWAY_WINNER_MSG=Congratulations {winners}! You won **{prize}**!

